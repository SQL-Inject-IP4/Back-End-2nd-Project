generator client {
  provider                = "prisma-client"
  output                  = "../src/generated/prisma"
  engineType              = "client"
  moduleFormat            = "cjs"
  generatedFileExtension  = "ts"
  importFileExtension     = ""
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  EDITOR
  VIEWER
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String?
  avatarUrl    String?
  googleId     String         @unique
  role         UserRole       @default(VIEWER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  styleUpdates StyleSetting[] @relation("StyleUpdatedBy")
}

model StyleSetting {
  id              String   @id
  backgroundColor String
  fontFamily      String
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedBy       User?    @relation("StyleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}
